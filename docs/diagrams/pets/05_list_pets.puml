@startuml 05_list_pets
title List Pets — GET /pets

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipantBorderColor #555555
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam sequenceGroupBorderColor #999999
skinparam noteBorderColor #BBBBBB
skinparam noteBackgroundColor #FFFDE7

actor Client

box "Presentation" #EEF4FB
  participant "pet_router" as Router
  participant "get_current_user\n<<dependency>>" as AuthDep
end box

box "Application" #FFF8E1
  participant "ListPetsHandler" as Handler
end box

box "Infrastructure" #FBE9E7
  participant "SqlitePetRepository" as Repo
end box

database "SQLite" as DB

autonumber

Client -> Router : GET /pets\nAuthorization: Bearer eyJhbGci…

Router -> AuthDep : resolve get_current_user(token)
alt token invalid
  AuthDep --> Router : raises InvalidTokenException
  Router --> Client : 401 Unauthorized
else token valid
  AuthDep --> Router : current_user_id

  Router -> Handler : ListPetsQuery(owner_id=current_user_id)

  Handler -> Repo : find_by_owner(current_user_id)
  Repo -> DB : SELECT pets.* FROM pets\nJOIN pet_owners ON pets.id = pet_owners.pet_id\nWHERE pet_owners.owner_id = ?
  DB --> Repo : rows (0 or more)
  Repo --> Handler : [Pet, …]
  note right of Handler : Returns only pets owned\nby the authenticated user.\nOther users' pets are never exposed.

  Handler --> Router : [PetDto, …]
  Router --> Client : 200 OK\n[ { "id", "name", "last_name",\n    "type", "owner_ids" }, … ]
end

@enduml
